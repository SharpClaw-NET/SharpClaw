{
  // SharpClaw Interface environment configuration.
  //
  // This client-side file is read directly by the Uno frontend. It controls
  // which backend URL the client targets and whether bundled child processes
  // are launched by the desktop app.

  "Api": {
    "Url": "http://127.0.0.1:48923"
  },

  "Logging": {
    "Serilog": {
      "Enabled": "true",
      "ConsoleEnabled": "true",
      "FileEnabled": "true",
      "RequestLoggingEnabled": "false",
      "MinimumLevel": "Information",
      "MicrosoftMinimumLevel": "Warning",
      "AspNetCoreMinimumLevel": "Warning",
      "EntityFrameworkCoreMinimumLevel": "Warning",
      "UnoMinimumLevel": "Warning"
    }
  },

  "Backend": {
    "Enabled": "true"
  },

  "Gateway": {
    "Enabled": "false",
    "Url": "http://0.0.0.0:48924"
  },

  "Processes": {
    "Persistent": "false",
    "AutoStart": "false"
  }
}
